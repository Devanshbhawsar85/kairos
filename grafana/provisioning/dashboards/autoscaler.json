{
  "title": "Auto-Scaler Dashboard",
  "uid": "autoscaler",
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "JVM CPU Usage",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "process_cpu_usage{job=~\"auto-scaler|main-app\"}",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "JVM Memory Used",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{job=~\"auto-scaler|main-app\", area=\"heap\"}",
          "legendFormat": "{{job}} heap"
        }
      ]
    },
    {
      "id": 3,
      "title": "HTTP Requests Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{job=\"main-app\"}[1m])",
          "legendFormat": "{{uri}} {{status}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Active Threads",
      "type": "stat",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 8 },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{job=\"auto-scaler\"}",
          "legendFormat": "Auto-Scaler Threads"
        }
      ]
    },
    {
      "id": 5,
      "title": "Kafka Consumer Lag",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "kafka_consumer_fetch_manager_records_lag{job=~\".*worker.*\"}",
          "legendFormat": "{{job}} lag"
        }
      ]
    }
  ],
  "schemaVersion": 36,
  "style": "dark",
  "tags": ["autoscaler", "docker", "kafka"]
}