📝 Configuration
Application Properties
yaml
# application.yml
autoscaler:
  docker:
    min-containers: 1
    max-containers: 5
    container-prefix: main-app

  scaling:
    cpu-threshold: 70.0
    memory-threshold: 80.0
    cooldown-seconds: 150

  monitoring:
    interval-seconds: 60

  vector-store:
    snapshot-retention: 500
    event-retention: 200
    top-k-snapshots: 20
    top-k-events: 10
